/* ========================================
   桂乡生活 - 共享组件样式 v2
   所有列表页公用（广场、失物招领、兼职等）
   ======================================== */

/* ---------- 卡片容器 ---------- */
.box {
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 30rpx 24rpx;
  background: var(--card-bg, #fff);
  box-shadow: var(--shadow, 0 4rpx 16rpx rgba(0,0,0,0.06));
  transition: transform 0.2s;
}
.box:active {
  transform: scale(0.98);
}

/* ---------- 顶部：标题 + 价格 ---------- */
.top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.title {
  font-size: var(--font-h2, 34rpx);
  font-weight: 600;
  color: var(--text-primary, #1A1A2E);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--danger, #EF4444);
  flex-shrink: 0;
  margin-left: 20rpx;
}

/* ---------- 分割线 ---------- */
.line {
  height: 2rpx;
  background: var(--border, #F0F0F0);
  margin: 16rpx 0;
}

/* ---------- 详情文本 ---------- */
.info {
  font-size: 28rpx;
  color: var(--text-secondary, #6B7280);
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

/* ---------- 图片滚动容器 ---------- */
.img_box {
  display: flex;
  flex-direction: row;
  margin-top: 16rpx;
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.img_box::-webkit-scrollbar {
  display: none;
}

/* ---------- 缩略图 ---------- */
.img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  background: var(--bg, #F5F6FA);
}

/* ---------- 卡片底部 ---------- */
.box_bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

/* ---------- 删除按钮 ---------- */
.delete {
  font-size: var(--font-caption, 24rpx);
  color: var(--danger, #EF4444);
  padding: 8rpx 24rpx;
  border: 2rpx solid var(--danger, #EF4444);
  border-radius: 30rpx;
}

/* ---------- 时间戳 ---------- */
.time {
  font-size: 24rpx;
  color: var(--text-placeholder, #9CA3AF);
  text-align: right;
}

/* ---------- 浮动发布按钮 ---------- */
.send {
  width: 260rpx;
  height: 96rpx;
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  margin-left: -130rpx;
  box-shadow: 0 8rpx 24rpx rgba(91, 127, 255, 0.35);
  border-radius: 48rpx;
  transition: all 0.2s;
  z-index: 10;
}
.send:active {
  width: 240rpx;
  height: 88rpx;
  bottom: 84rpx;
  margin-left: -120rpx;
  opacity: 0.85;
}

/* ---------- 加载状态 ---------- */
.loading-text {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-placeholder, #9CA3AF);
  font-size: 28rpx;
}

/* ---------- 空状态 ---------- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  color: var(--text-placeholder, #9CA3AF);
  font-size: 28rpx;
}
