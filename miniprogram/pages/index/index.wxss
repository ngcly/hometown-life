/* ========================================
   桂乡生活 - 首页
   ======================================== */

page {
  background-color: var(--bg, #F5F6FA);
}

.all {
  width: 95vw;
  margin: auto;
  padding-bottom: 40rpx;
}

/* 桂花装饰 */
.osmanthus-deco {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 14rpx;
  padding: 16rpx 0 0;
}
.osmanthus-flower {
  font-size: 24rpx;
  color: #E8A33D;
  animation: osmanthus-bloom 2s ease-in-out infinite;
  display: inline-block;
}
.osmanthus-flower:nth-child(1) { animation-delay: 0s; }
.osmanthus-flower:nth-child(2) { animation-delay: 0.3s; }
.osmanthus-flower:nth-child(3) { animation-delay: 0.6s; }
.osmanthus-flower:nth-child(4) { animation-delay: 0.9s; }
.osmanthus-flower:nth-child(5) { animation-delay: 1.2s; }

@keyframes osmanthus-bloom {
  0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.5; }
  50% { transform: scale(1.4) rotate(180deg); opacity: 1; }
}

/* 季节问候 */
.season-greeting {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0 6rpx;
  gap: 10rpx;
}
.greeting-icon {
  font-size: 28rpx;
}
.greeting-text {
  font-size: 24rpx;
  color: var(--text-secondary, #6B7280);
  letter-spacing: 2rpx;
}

/* 搜索入口 */
.search-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #E8A33D 0%, #D4872B 100%);
  border-radius: 50rpx;
  margin: 24rpx 0 20rpx;
  padding: 22rpx 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(232, 163, 61, 0.35);
}

.search-icon {
  font-size: 34rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  flex: 1;
}

/* ===== 轮播图（卡片式横向布局） ===== */
swiper.banner-swiper {
  height: 200rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(232, 163, 61, 0.2);
}

swiper.banner-swiper swiper-item {
  border-radius: 24rpx;
  overflow: hidden;
}

.slide-bg {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 0 36rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.slide-bg::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -10%;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.10);
  border-radius: 50%;
}

.slide-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  z-index: 1;
}

.slide-icon {
  font-size: 80rpx;
  margin-left: 10rpx;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
  z-index: 1;
}

.slide-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
  letter-spacing: 2rpx;
}

.slide-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

.slide-tags {
  display: flex;
  flex-direction: row;
  margin-top: 14rpx;
  gap: 12rpx;
}

.slide-tag {
  font-size: 20rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

/* 快捷入口 九宫格 */
.quick-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin: 24rpx 0;
  background: var(--card-bg, white);
  border-radius: 24rpx;
  padding: 28rpx 0 20rpx;
  box-shadow: var(--shadow, 0 4rpx 16rpx rgba(0, 0, 0, 0.06));
}

.quick-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 0 16rpx;
}

.quick-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.quick-icon-wrap image {
  width: 52rpx;
  height: 52rpx;
}

.quick-item text {
  font-size: 24rpx;
  color: #555;
}

/* 最新动态 */
.feed-section {
  background: var(--card-bg, white);
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  box-shadow: var(--shadow, 0 4rpx 16rpx rgba(0, 0, 0, 0.06));
  margin-bottom: 30rpx;
}

.feed-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border, #F0F0F0);
}

.feed-title {
  font-size: 32rpx;
  font-weight: 700;
}

.feed-more {
  font-size: 24rpx;
  color: var(--primary, #E8A33D);
}

.feed-loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-secondary, #6B7280);
  font-size: 28rpx;
}

.feed-empty {
  text-align: center;
  padding: 40rpx;
  color: var(--text-placeholder, #9CA3AF);
  font-size: 28rpx;
}

.feed-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border, #F0F0F0);
}

.feed-item:last-child {
  border-bottom: none;
}

.feed-label {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  color: white;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feed-label-xianzhi { background: var(--primary, #E8A33D); }
.feed-label-lost { background: var(--danger, #EF4444); }
.feed-label-found { background: var(--success, #10B981); }
.feed-label-jianzhi { background: var(--warning, #F59E0B); }
.feed-label-biaobai { background: var(--love, #EC4899); }

.feed-content {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  overflow: hidden;
}

.feed-text {
  font-size: 26rpx;
  color: var(--text-primary, #1A1A2E);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.feed-time {
  font-size: 22rpx;
  color: var(--text-placeholder, #9CA3AF);
  margin-left: 15rpx;
  flex-shrink: 0;
}
