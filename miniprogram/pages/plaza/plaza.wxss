@import "../../styles/shared.wxss";

/* ===== 类型筛选标签 ===== */
.type-bar {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 20rpx 30rpx;
  margin-bottom: 10rpx;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.type-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 14rpx;
  font-size: var(--font-body, 28rpx);
  color: var(--text-secondary, #6B7280);
  background: var(--card-bg, #fff);
  border-radius: 40rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 8rpx rgba(0,0,0,0.05));
  transition: all 0.2s;
}

.type-tab.active {
  color: #fff;
  background: var(--primary, #E8A33D);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(91, 127, 255, 0.3);
}

/* ===== 信息卡片 ===== */
.plaza-card {
  background: var(--card-bg, #fff);
  border-radius: 20rpx;
  margin: 0 30rpx 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow, 0 4rpx 16rpx rgba(0,0,0,0.06));
  position: relative;
}

/* 封面大图 */
.card-cover-wrap {
  width: 100%;
  height: 340rpx;
  overflow: hidden;
}

.card-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.card-cover-placeholder {
  width: 100%;
  height: 160rpx;
  background: var(--bg, #F5F6FA);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-caption, 24rpx);
  color: var(--text-placeholder, #9CA3AF);
}

/* 类型角标 */
.card-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
}

/* 信息区域 */
.card-body {
  padding: 24rpx;
}

.card-title {
  font-size: var(--font-h2, 34rpx);
  font-weight: 600;
  color: var(--text-primary, #1A1A2E);
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.card-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--danger, #EF4444);
}

.card-info-text {
  font-size: var(--font-body, 28rpx);
  color: var(--text-secondary, #6B7280);
}

.card-desc {
  font-size: var(--font-body, 28rpx);
  color: var(--text-secondary, #6B7280);
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 16rpx;
}

/* 底部 */
.card-footer {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--border, #F0F0F0);
}

.card-user {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.card-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: var(--bg, #F5F6FA);
  flex-shrink: 0;
}

.card-username {
  font-size: var(--font-caption, 24rpx);
  color: var(--text-placeholder, #9CA3AF);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.card-time {
  font-size: var(--font-small, 22rpx);
  color: var(--text-placeholder, #9CA3AF);
  flex-shrink: 0;
}

.card-delete {
  font-size: 22rpx;
  color: var(--danger, #EF4444);
  padding: 6rpx 16rpx;
  border: 2rpx solid var(--danger, #EF4444);
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ===== 浮动发布按钮 ===== */
.fab {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #E8A33D, #F5A623);
  color: #fff;
  padding: 20rpx 52rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 28rpx rgba(91, 127, 255, 0.4);
  z-index: 10;
  transition: all 0.2s;
}
.fab:active {
  opacity: 0.88;
  transform: translateX(-50%) scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(91, 127, 255, 0.3);
}
.fab-icon { font-size: 36rpx; }
.fab-text { font-size: 30rpx; font-weight: 600; letter-spacing: 2rpx; }

/* ===== 通用状态 ===== */
.loading-text {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-placeholder, #9CA3AF);
  font-size: var(--font-body, 28rpx);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
  color: var(--text-placeholder, #9CA3AF);
  font-size: var(--font-body, 28rpx);
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.hint { font-size: var(--font-caption, 24rpx); margin-top: 12rpx; }
