/* ========================================
   桂乡生活 - 「我的」页面 v2
   ======================================== */

page {
  background-color: var(--bg, #F5F6FA);
  padding-bottom: 40rpx;
}

/* ---------- 用户头像区域 ---------- */
.profile-section {
  background: linear-gradient(135deg, #E8A33D 0%, #D4872B 100%);
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 auto 20rpx;
  line-height: 1;
  background: none;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  overflow: hidden;
  display: block;
  text-align: center;
}
.avatar-btn::after {
  border: none;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
}
.avatar image,
.avatar-btn image {
  width: 100%;
  height: 100%;
}

.nickname-display {
  min-height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nickname-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.nickname-hint {
  font-size: 30rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.7);
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(255, 255, 255, 0.15);
  border: 0;
  outline: none;
  text-align: center;
  padding: 4rpx 16rpx;
  margin: 0;
  height: 50rpx;
  line-height: 50rpx;
  width: auto;
  max-width: 400rpx;
  min-width: 100rpx;
  border-radius: 8rpx;
}

.login-tip {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.login-btn {
  height: 72rpx;
  line-height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 28rpx;
  border: none;
  border-radius: 40rpx;
  padding: 0 48rpx;
  margin-top: 16rpx;
  backdrop-filter: blur(4px);
}
.login-btn::after {
  border: none;
}

/* ---------- 菜单卡片 ---------- */
.menu-section {
  margin: 24rpx 30rpx 0;
  background: var(--card-bg, #fff);
  border-radius: 24rpx;
  box-shadow: var(--shadow, 0 4rpx 16rpx rgba(0,0,0,0.06));
  overflow: hidden;
}

.menu-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid var(--border, #F0F0F0);
}
.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.menu-left image {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}
.menu-left text {
  font-size: 28rpx;
  color: var(--text-primary, #1A1A2E);
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
}

/* ---------- 分享按钮（伪装成菜单项） ---------- */
.menu-btn-full {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 28rpx 32rpx;
  margin: 0;
  line-height: 1;
  background: none;
  border: none;
  border-radius: 0;
  text-align: left;
  border-bottom: 2rpx solid var(--border, #F0F0F0);
}
.menu-btn-full::after {
  border: none;
}
.menu-btn-full:last-child {
  border-bottom: none;
}

/* ---------- 协议卡片 ---------- */
.policy-section {
  margin-top: 24rpx;
}

.policy-text {
  font-size: 28rpx;
  color: var(--text-secondary, #6B7280);
}

/* ---------- 版本号 ---------- */
.footer-version {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-placeholder, #9CA3AF);
  margin-top: 40rpx;
  padding-bottom: 8rpx;
}

.footer-copyright {
  text-align: center;
  font-size: 20rpx;
  color: var(--text-placeholder, #9CA3AF);
  line-height: 1.6;
}

/* ---------- 展开的统计数据 ---------- */
.stats-list {
  background: var(--primary-light, #FFF8E1);
}
.stats-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 20rpx 72rpx;
  font-size: 26rpx;
  color: var(--text-secondary, #6B7280);
  border-bottom: 2rpx solid var(--border, #F0F0F0);
}
.stats-item:last-child {
  border-bottom: none;
}
.stats-item text:last-child {
  color: var(--primary, #E8A33D);
  font-weight: 600;
}

/* ---------- 我的帖子列表 ---------- */
.my-posts {
  background: var(--card-bg, #fff);
}

.posts-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary, #6B7280);
  padding: 20rpx 32rpx 12rpx;
}

.posts-loading {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: var(--text-placeholder, #9CA3AF);
}

.posts-empty {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: var(--text-placeholder, #9CA3AF);
}

.post-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 32rpx;
  border-bottom: 2rpx solid var(--border, #F0F0F0);
}
.post-item:last-child {
  border-bottom: none;
}

.post-label {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.post-label-xianzhi,
.post-label-items { background: var(--primary, #E8A33D); }
.post-label-lost { background: var(--danger, #EF4444); }
.post-label-found { background: var(--success, #10B981); }
.post-label-biaobai,
.post-label-confessions { background: var(--love, #EC4899); }
.post-label-jianzhi,
.post-label-jobs { background: var(--warning, #F59E0B); }
.post-label-food { background: #F97316; }
.post-label-travel { background: #3B82F6; }
.post-label-amusement,
.post-label-entertainment { background: #A855F7; }
.post-label-zufang,
.post-label-rentals { background: var(--gold, #F5A623); }
.post-label-story { background: #EC4899; }

.post-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.post-text {
  font-size: 26rpx;
  color: var(--text-primary, #1A1A2E);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-time {
  font-size: 20rpx;
  color: var(--text-placeholder, #9CA3AF);
  margin-top: 4rpx;
}

.post-delete {
  font-size: 22rpx;
  color: var(--danger, #EF4444);
  padding: 8rpx 16rpx;
  border: 2rpx solid var(--danger, #EF4444);
  border-radius: 24rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}
