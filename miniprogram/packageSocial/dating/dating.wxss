/* ========================================
   桂乡生活 - 同城交友页 v2
   ======================================== */

page {
  background-color: var(--bg, #F5F6FA);
}

.all {
  display: flex;
  flex-direction: column;
  width: 90vw;
  margin: auto;
  padding: 20rpx 0;
}

.box {
  border-radius: 24rpx;
  margin-top: 24rpx;
  background: var(--card-bg, #fff);
  width: 84vw;
  padding: 28rpx 30rpx;
  box-shadow: var(--shadow, 0 4rpx 16rpx rgba(0,0,0,0.06));
}
.box:last-of-type {
  margin-bottom: 30rpx;
}

.title {
  font-size: var(--font-h2, 34rpx);
  font-weight: 600;
  color: var(--love, #EC4899);
  margin-bottom: 12rpx;
}

.info {
  font-size: var(--font-body, 28rpx);
  color: var(--text-secondary, #6B7280);
  line-height: 1.7;
  text-align: justify;
  margin: 8rpx 0;
}

.box_bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.delete {
  font-size: 24rpx;
  color: var(--danger, #EF4444);
}

.writer {
  font-size: 24rpx;
  color: var(--text-placeholder, #9CA3AF);
  text-align: right;
}

/* ---------- 浮动发布按钮 ---------- */
.send {
  width: 260rpx;
  height: 96rpx;
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  margin-left: -130rpx;
  box-shadow: 0 8rpx 24rpx rgba(236, 72, 153, 0.35);
  border-radius: 48rpx;
  transition: all 0.2s;
  z-index: 10;
}
.send:active {
  width: 240rpx;
  height: 88rpx;
  bottom: 84rpx;
  margin-left: -120rpx;
  opacity: 0.85;
}

/* ---------- 弹窗 ---------- */
.send_bg {
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.45);
  position: fixed;
  top: 0;
  left: 0;
  z-index: 20;
}

.send_box {
  width: 600rpx;
  background: var(--card-bg, #fff);
  border-radius: 24rpx;
  overflow: hidden;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 21;
  box-shadow: var(--shadow-lg, 0 8rpx 30rpx rgba(0,0,0,0.12));
}

.top {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #EC4899, #F472B6);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.center {
  padding: 24rpx;
}

.center input {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1A1A2E);
  background: var(--bg, #F5F6FA);
  border-radius: 12rpx;
  padding: 0 20rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
  border: none;
}

textarea {
  width: 100%;
  min-height: 150rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1A1A2E);
  background: var(--bg, #F5F6FA);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  border: none;
  line-height: 1.5;
}

.send_button {
  display: flex;
  flex-direction: row;
}

.send_button button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
  font-size: 28rpx;
}
.send_button button::after {
  border: none;
}

.b1 {
  background: var(--bg, #F5F6FA);
  color: var(--text-secondary, #6B7280);
  border-radius: 0;
}

.b2 {
  background: linear-gradient(135deg, #EC4899, #F472B6);
  color: #fff;
  border-radius: 0;
}
