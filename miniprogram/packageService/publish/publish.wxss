/* ========================================
   桂乡生活 - 发布页 v2
   ======================================== */

page {
  background-color: var(--bg, #F5F6FA);
  width: 98%;
  margin: auto;
}

.all {
  width: 90vw;
  margin: auto;
  padding-bottom: 120rpx;
}

.box {
  border-radius: 24rpx;
  background: var(--card-bg, #fff);
  margin-top: 24rpx;
  padding: 24rpx 30rpx;
  box-shadow: var(--shadow, 0 4rpx 16rpx rgba(0,0,0,0.06));
}

.box_top {
  font-size: var(--font-h3, 30rpx);
  font-weight: 600;
  color: var(--text-primary, #1A1A2E);
  padding: 8rpx 0;
}

.line {
  height: 2rpx;
  background: var(--border, #F0F0F0);
  margin: 16rpx 0;
}

.box_center {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin: 8rpx 0;
}

.left {
  width: 25%;
  font-size: 28rpx;
  color: var(--text-secondary, #6B7280);
  line-height: 72rpx;
  flex-shrink: 0;
}

input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1A1A2E);
  background: var(--bg, #F5F6FA);
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

textarea {
  flex: 1;
  min-height: 140rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1A1A2E);
  background: var(--bg, #F5F6FA);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  line-height: 1.5;
}

/* ---------- 分类选择器 ---------- */
.picker-text {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: var(--text-primary, #1A1A2E);
  background: var(--bg, #F5F6FA);
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.picker-text.placeholder {
  color: var(--text-placeholder, #9CA3AF);
}

/* ---------- 图片上传区域 ---------- */
.images_box {
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 8rpx 0;
}
.images_box::-webkit-scrollbar {
  display: none;
}

.img-box {
  display: inline-block;
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  border: 2rpx dashed var(--border, #F0F0F0);
  margin-right: 16rpx;
  position: relative;
  overflow: hidden;
  background: var(--bg, #F5F6FA);
  vertical-align: top;
}

.img {
  width: 100%;
  height: 100%;
}

.img-delect {
  width: 36rpx;
  height: 36rpx;
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  z-index: 2;
}

/* ---------- 提交按钮 ---------- */
button {
  width: 100vw;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #E8A33D, #F5A623);
  color: #fff;
  font-size: var(--font-h3, 30rpx);
  font-weight: 600;
  border: none;
  border-radius: 0;
  position: fixed;
  bottom: 0;
  left: 0;
  z-index: 10;
}
button::after {
  border: none;
}
button:active {
  opacity: 0.85;
}
