/* ========================================
   桂乡生活 - 娱乐页面
   ======================================== */

page {
  background-color: var(--bg, #F5F6FA);
}

.header-bg {
  background: linear-gradient(135deg, #E8A33D, #F5A623);
  padding: 60rpx 40rpx 80rpx;
  text-align: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-icon { font-size: 72rpx; margin-bottom: 12rpx; }
.header-title { font-size: 40rpx; font-weight: 700; color: #fff; letter-spacing: 4rpx; }
.header-sub { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

.list-wrap {
  margin-top: -40rpx;
  padding: 0 30rpx 120rpx;
  position: relative;
  z-index: 2;
}

.card {
  background: var(--card-bg, #fff);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow, 0 4rpx 16rpx rgba(0,0,0,0.06));
  position: relative;
}

.card-name {
  font-size: var(--font-h2, 34rpx);
  font-weight: 600;
  color: var(--text-primary, #1A1A2E);
  margin-bottom: 8rpx;
}

.card-meta {
  font-size: var(--font-body, 28rpx);
  color: var(--text-secondary, #6B7280);
  line-height: 1.6;
}

.card-divider {
  height: 2rpx;
  background: var(--border, #F0F0F0);
  margin: 14rpx 0;
}

.card-info {
  font-size: var(--font-body, 28rpx);
  color: var(--text-secondary, #6B7280);
  line-height: 1.7;
  text-align: justify;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 14rpx;
}

.card-author { font-size: var(--font-caption, 24rpx); color: var(--text-placeholder, #9CA3AF); }
.card-time { font-size: var(--font-small, 22rpx); color: var(--text-placeholder, #9CA3AF); }

.delete-btn {
  position: absolute; top: 16rpx; right: 16rpx;
  font-size: 22rpx; color: var(--danger, #EF4444);
  padding: 6rpx 16rpx;
  border: 2rpx solid var(--danger, #EF4444);
  border-radius: 20rpx;
}

.fab {
  position: fixed; bottom: 80rpx; left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #E8A33D, #F5A623);
  color: #fff; padding: 20rpx 48rpx; border-radius: 50rpx;
  display: flex; align-items: center; gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(232, 163, 61, 0.35);
  z-index: 10;
}
.fab:active { opacity: 0.85; transform: translateX(-50%) scale(0.96); }
.fab-icon { font-size: 32rpx; }
.fab-text { font-size: 28rpx; font-weight: 500; }

.modal-mask {
  position: fixed; top: 0; left: 0;
  width: 100vw; height: 100vh;
  background: rgba(0,0,0,0.45);
  z-index: 20;
}
.modal-box {
  position: fixed; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: var(--card-bg, #fff);
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 21;
  box-shadow: var(--shadow-lg, 0 8rpx 30rpx rgba(0,0,0,0.12));
}
.modal-header {
  height: 88rpx; line-height: 88rpx;
  background: linear-gradient(135deg, #E8A33D, #F5A623);
  color: #fff; font-size: 32rpx; font-weight: 600; text-align: center;
}
.modal-body { padding: 28rpx; }
.modal-input {
  width: 100%; height: 72rpx; line-height: 72rpx;
  font-size: 28rpx; color: var(--text-primary, #1A1A2E);
  background: var(--bg, #F5F6FA); border-radius: 12rpx;
  padding: 0 20rpx; margin-bottom: 16rpx; box-sizing: border-box;
}
.modal-textarea {
  width: 100%; min-height: 150rpx;
  font-size: 28rpx; color: var(--text-primary, #1A1A2E);
  background: var(--bg, #F5F6FA); border-radius: 12rpx;
  padding: 16rpx 20rpx; box-sizing: border-box; line-height: 1.5;
}
.modal-footer { display: flex; flex-direction: row; }
.modal-btn { flex: 1; height: 80rpx; line-height: 80rpx; text-align: center; font-size: 28rpx; }
.modal-btn-cancel { background: var(--bg, #F5F6FA); color: var(--text-secondary, #6B7280); }
.modal-btn-confirm { background: linear-gradient(135deg, #E8A33D, #F5A623); color: #fff; }

.loading-text { text-align: center; padding: 40rpx 0; color: var(--text-placeholder, #9CA3AF); font-size: var(--font-body, 28rpx); }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 40vh; color: var(--text-placeholder, #9CA3AF); font-size: var(--font-body, 28rpx); }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.hint { font-size: var(--font-caption, 24rpx); margin-top: 12rpx; }
