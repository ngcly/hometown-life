@import "../../styles/shared.wxss";

/* ========== Tab 切换栏 ========== */
.tab-h {
  display: flex;
  flex-direction: row;
  background: var(--card-bg, #fff);
  height: 88rpx;
  justify-content: space-around;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: var(--font-body, 28rpx);
  font-weight: 500;
  color: var(--text-secondary, #6B7280);
  line-height: 88rpx;
  position: relative;
  transition: color 0.3s;
}

.tab-item.active {
  color: var(--primary, #E8A33D);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--primary, #E8A33D);
  border-radius: 4rpx;
}

/* ========== Swiper ========== */
swiper {
  height: calc(100vh - 88rpx);
}

/* ========== 弹窗遮罩 ========== */
.bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.45);
  z-index: 20;
}

.show_send {
  position: fixed;
  top: 0;
  z-index: 21;
}

.show_button {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: row;
  gap: 30rpx;
  z-index: 22;
}

.show_button button {
  width: 200rpx;
  height: 200rpx;
  text-align: center;
  line-height: 200rpx;
  border-radius: 20rpx;
  background: var(--card-bg, #fff);
  box-shadow: var(--shadow-lg, 0 8rpx 30rpx rgba(0,0,0,0.1));
  font-size: 28rpx;
  border: none;
}
.show_button button:active {
  transform: scale(0.95);
}
.show_button button::after {
  border: none;
}
